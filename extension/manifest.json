{
  "manifest_version": 3,
  "name": "Privacy Shield",
  "version": "1.0.0",
  "description": "Protects against Canvas, WebGL, and AudioContext fingerprinting",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
